# Shared dev/local secrets — committed to the repo on purpose.
# These keys ONLY decrypt the local Postgres development database.
# DO NOT reuse them in staging or production.
#
# To bootstrap a fresh checkout:
#   cp .env.dev .env
# Then `cargo run -p gmed-server` will pick them up automatically.
#
# `.env` itself stays in .gitignore so you can locally override values
# without accidentally committing them.

DATABASE_URL=postgres://gmed:gmed@localhost:5432/gmed
PORT=3000
JWT_SECRET=KRSOXdAKeW3SSbzxDIuzzkyOgqfXkfLIrn+oymtaBez73TZYXMAHYDyAX1gg9iiC

# Comma-separated `id:base64key` pairs (each key is 32 bytes).
# The first id is active by default; override with MESSAGE_ENCRYPTION_KEY_ACTIVE.
MESSAGE_ENCRYPTION_KEYS=v1:baybAFeou0OBWH9SMwxuULBK3HzmN4bZ+krBczzk0tQ=
MESSAGE_ENCRYPTION_KEY_ACTIVE=v1

CORS_ORIGIN=http://localhost:5174
RUST_LOG=info,gmed_server=debug
