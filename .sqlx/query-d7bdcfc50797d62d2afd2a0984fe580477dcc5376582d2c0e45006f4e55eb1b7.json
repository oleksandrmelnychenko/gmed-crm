  "query": "SELECT a.id, a.title, a.message, a.variant, a.is_active,\n                  a.starts_at, a.ends_at, a.created_at,\n                  u.name AS \"creator!\"\n           FROM announcements a\n           JOIN users u ON u.id = a.created_by\n           ORDER BY a.created_at DESC LIMIT 50",
