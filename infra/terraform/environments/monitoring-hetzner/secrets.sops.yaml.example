# Template for the monitoring sops-encrypted secrets bundle.
#
# Workflow:
#   1. Generate a SEPARATE age key for monitoring:
#        age-keygen -o ~/.config/sops/age/gmed-monitoring.key
#      Add the `age1...` public line to a new rule in
#      `infra/terraform/.sops.yaml` for `environments/monitoring-hetzner/.*`.
#   2. Copy this file to `secrets.sops.yaml`, fill in values, encrypt:
#        sops -e -i secrets.sops.yaml

# --- Tailscale -------------------------------------------------------
# Pre-auth key tagged `tag:gmed-monitoring` (separate tag from PROD so
# the ACL can grant the monitoring server outbound access to PROD's
# tailnet IP for scraping while denying everything else).
TAILSCALE_AUTH_KEY: "tskey-auth-REPLACE-WITH-MONITORING-KEY"
TAILSCALE_HOSTNAME: "gmed-monitoring"

# --- Grafana ---------------------------------------------------------
# Admin password for the built-in admin user. Rotate via the same
# sops-edit-and-redeploy flow as everything else.
# Generate: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD: "REPLACE-WITH-openssl-rand-base64-24"

# Secret used to sign session cookies. Rotating invalidates all
# Grafana sessions.
# Generate: openssl rand -base64 32
GRAFANA_SECRET_KEY: "REPLACE-WITH-openssl-rand-base64-32"

# --- Alertmanager: email delivery ------------------------------------
# Generic SMTP relay (Hetzner does not provide one — use Resend,
# Mailgun, Postmark, Brevo, or any account-based SMTP).
ALERTMANAGER_SMTP_HOST: "smtp.example.com:587"
ALERTMANAGER_SMTP_FROM: "alerts@gmed-health.com"
ALERTMANAGER_SMTP_USERNAME: "REPLACE"
ALERTMANAGER_SMTP_PASSWORD: "REPLACE"
ALERTMANAGER_TO_EMAIL: "ops@gmed-health.com"

# --- Healthchecks.io: monitor the monitor ----------------------------
# An external ping URL that the monitoring host pings every 5 minutes.
# A missed ping fires an alert through Healthchecks.io's own channels —
# this is "who watches the watcher".
MONITORING_HEALTHCHECKS_PING_URL: "https://hc-ping.com/REPLACE-WITH-UUID"
