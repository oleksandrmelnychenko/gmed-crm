# Template for the PROD sops-encrypted secrets bundle.
#
# Workflow (one-time):
#   1. Generate the PROD age key (DIFFERENT from DEV):
#        age-keygen -o ~/.config/sops/age/gmed-prod.key
#   2. Put the `age1...` public line in `infra/terraform/.sops.yaml`
#      under the `environments/prod-hetzner/.*` rule.
#   3. Store the AGE-SECRET-KEY-1... private line in a vault meant for
#      PROD secrets (1Password Business vault, separate access list).
#   4. Copy this file to `secrets.sops.yaml`, fill values, then:
#        sops -e -i secrets.sops.yaml
#
# Every random value below MUST be unique to PROD — never reuse DEV
# credentials. Generate with `openssl rand -base64 <len>` as noted.

# --- Postgres credentials (PROD) --------------------------------------------
# The hardcoded "gmed/gmed/gmed" in docker-compose.yml is overridden
# here in PROD. GMED_DATABASE_URL below must reference the same
# user/password/db — they are kept in sync inside this bundle.
POSTGRES_DB: "gmed"
POSTGRES_USER: "gmed"
# 32+ random characters. openssl rand -base64 32
POSTGRES_PASSWORD: "REPLACE-WITH-openssl-rand-base64-32"

# Matches POSTGRES_* above.
GMED_DATABASE_URL: "postgres://gmed:REPLACE-WITH-openssl-rand-base64-32@postgres:5432/gmed"

# --- Application secrets ----------------------------------------------------
# openssl rand -base64 48
GMED_JWT_SECRET: "REPLACE-WITH-openssl-rand-base64-48"

# Comma-separated `keyid:base64-32-bytes`. The active id below must
# match one of these. Generate: openssl rand -base64 32
GMED_MESSAGE_ENCRYPTION_KEYS: "v1:REPLACE-WITH-openssl-rand-base64-32"
GMED_MESSAGE_ENCRYPTION_KEY_ACTIVE: "v1"

# Stable salt — rotating it breaks historical audit correlations.
# openssl rand -base64 32
GMED_AUDIT_IP_SALT: "REPLACE-WITH-openssl-rand-base64-32"

# Shared token accepted by /api/v1/public/lead-intake. The public website's
# LEAD_INTAKE_TOKEN must use the same value.
GMED_LEAD_INTAKE_TOKEN: "REPLACE-WITH-openssl-rand-base64-32"

GMED_CORS_ORIGIN: "https://console.gmed-health.com"

# --- One-time clean production bootstrap ------------------------------------
# First PROD deploy should not inherit demo/business seed data from migrations.
# With this flag true, deploy-prod.sh runs scripts/sanitize-prod-db.sh once:
# it keeps schema/reference dictionaries/system settings, truncates data
# tables, and leaves exactly this admin user. A host marker plus a DB marker
# prevents the wipe from running again on later deploys/restores.
PROD_EMPTY_DATABASE_ON_FIRST_DEPLOY: "true"
PROD_ADMIN_EMAIL: "admin@gmed.de"
PROD_ADMIN_NAME: "System Admin"
# Generate a strong initial password and rotate after first login.
# openssl rand -base64 32
PROD_ADMIN_PASSWORD: "REPLACE-WITH-openssl-rand-base64-32"

# --- Edge proxy / Caddy -----------------------------------------------------
CADDY_HOSTNAME: "console.gmed-health.com"
ACME_EMAIL: "ops@gmed-health.com"

# --- Observability (optional) -----------------------------------------------
# Healthchecks.io ping URL. The bootstrap cron pings this every 5 min
# after a successful local /health probe. Free tier is enough for a
# single endpoint. Phase 3 replaces this with a self-hosted monitoring
# server.
HEALTHCHECKS_PING_URL: "https://hc-ping.com/REPLACE-WITH-UUID"

# --- Off-host encrypted backups (Hetzner Object Storage) --------------------
# The backup pipeline streams pg_dump → age-encrypt → upload. The age
# PRIVATE key is NEVER on the server; only the recipients (public keys)
# live here. Restore requires SCPing the private key onto the host
# temporarily — see scripts/restore-postgres.sh.

# Region endpoint. Hetzner Object Storage exposes one per region:
#   fsn1 -> https://fsn1.your-objectstorage.com
#   nbg1 -> https://nbg1.your-objectstorage.com
BACKUP_S3_ENDPOINT: "https://nbg1.your-objectstorage.com"

# Some S3 SDKs require a region string. Hetzner accepts "auto" or the
# region prefix (fsn1, nbg1). Either works.
BACKUP_S3_REGION: "nbg1"

# Bucket name. Create it in Hetzner Console once: Object Storage →
# Create Bucket, enable Versioning, leave Object Lock off until Phase 4
# (Hetzner GA status varies by region).
BACKUP_S3_BUCKET: "gmed-prod-backups"

# Access credentials. Generate in Hetzner Console → Security → Object
# Storage credentials. Use a key dedicated to this PROD project; do not
# reuse DEV credentials.
BACKUP_S3_ACCESS_KEY: "REPLACE-WITH-OBJECT-STORAGE-ACCESS-KEY"
BACKUP_S3_SECRET_KEY: "REPLACE-WITH-OBJECT-STORAGE-SECRET-KEY"

# age recipients (PUBLIC keys, one per line — at minimum two so a lost
# private key does not destroy the archive). Generate locally:
#   age-keygen -o ~/.config/sops/age/gmed-backup-master.key
#   age-keygen -o ~/.config/sops/age/gmed-backup-recovery.key
#
# Store the PRIVATE keys offline:
#   - master   → 1Password "gmed prod backup master"
#   - recovery → physically separate location (paper, safe deposit,
#                separate hardware key)
#
# Paste only the public `age1...` lines below. The block scalar (`|`)
# preserves the multi-line layout sops needs to pass to `age -R`.
BACKUP_AGE_RECIPIENTS: |
  age1REPLACEMEPUBLICKEYMASTERxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  age1REPLACEMEPUBLICKEYRECOVERYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Separate Healthchecks.io ping URL for the backup cron (distinct from
# HEALTHCHECKS_PING_URL above). The free tier supports per-check grace
# periods and alerting — set the schedule to "daily" with a 4h grace.
BACKUP_HEALTHCHECKS_PING_URL: "https://hc-ping.com/REPLACE-WITH-BACKUP-UUID"

# --- Tailscale admin overlay -------------------------------------------------
# Generate at https://login.tailscale.com/admin/settings/keys.
# Recommended settings:
#   - Reusable          (so re-bootstraps don't need a fresh key)
#   - Non-ephemeral     (server keeps a stable tailnet identity)
#   - Pre-approved      (no manual approval after every deploy)
#   - Tagged (`tag:gmed-prod`), with the tag's owner = your operator
#     account in the Tailscale ACL.
#
# The ACL in the Tailscale admin controls who can SSH into devices
# carrying `tag:gmed-prod`. Recommended: limit to specific operator
# accounts (group:admins).
TAILSCALE_AUTH_KEY: "tskey-auth-REPLACE-WITH-PROD-KEY"

# Hostname registered in the tailnet. Conventional: match the public
# hostname so `ssh gmed@gmed-prod` works once Tailscale's MagicDNS is
# enabled in your tailnet.
TAILSCALE_HOSTNAME: "gmed-prod"

# --- Release image pins (GHCR + cosign) -------------------------------------
# Both refs MUST be digest-pinned (`@sha256:...`). Floating tags like
# `:main` are rejected by deploy-prod.sh because the digest could
# rotate between the cosign verify and the docker pull.
#
# Workflow:
#   1. Push to main (or push a v* tag) triggers .github/workflows/release.yml.
#   2. The job summary on GitHub Actions prints the freshly-built
#      digests (formatted as `GMED_*_IMAGE=ghcr.io/...@sha256:...`).
#   3. Paste those values here, re-encrypt: `sops -e -i secrets.sops.yaml`.
#   4. Run `sudo /opt/gmed/repo/scripts/deploy-prod.sh` on the host.
#
# The deploy script cosign-verifies the certificate identity matches
# .github/workflows/release.yml in THIS repository, so an attacker
# pushing a malicious image under a similarly-named tag cannot pass
# verification.
GMED_BACKEND_IMAGE: "ghcr.io/oleksandrmelnychenko/gmed-crm-server@sha256:REPLACE-WITH-DIGEST"
GMED_FRONTEND_IMAGE: "ghcr.io/oleksandrmelnychenko/gmed-crm-frontend@sha256:REPLACE-WITH-DIGEST"

# --- Postgres metrics user (Phase 3e2) ---------------------------------------
# Dedicated read-only user for postgres_exporter, distinct from the
# application's POSTGRES_USER. The user must exist in Postgres with
# the pg_monitor role — created one-time via SQL after the first
# deploy (see PROD README "Phase 3e2 metrics-user setup"). The
# password below is what you use in that CREATE USER statement.
#
# Why a separate user: pg_monitor is read-only to the catalog and
# stats; even a compromised exporter cannot read application data or
# mutate state.
# Generate: openssl rand -base64 32
POSTGRES_METRICS_USER: "gmed_metrics"
POSTGRES_METRICS_PASSWORD: "REPLACE-WITH-openssl-rand-base64-32"

# --- Loki shipper URL (Phase 3e2) --------------------------------------------
# Promtail on PROD pushes to Loki on the monitoring host via the
# tailnet. `gmed-monitoring` is the Tailscale MagicDNS name set by
# the monitoring server's `TAILSCALE_HOSTNAME`. Override with the
# literal 100.x.y.z if MagicDNS is disabled.
LOKI_URL: "http://gmed-monitoring:3100/loki/api/v1/push"
