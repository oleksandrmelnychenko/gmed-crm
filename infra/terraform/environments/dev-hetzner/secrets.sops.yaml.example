# Template for the sops-encrypted secrets bundle the host decrypts at
# boot. Copy to `secrets.sops.yaml` next to this file, fill in real
# values, then encrypt in place:
#
#   sops -e -i secrets.sops.yaml
#
# After encryption sops rewrites the file with `sops:` metadata at the
# end; the plaintext above is replaced with ciphertext. Re-edit with
# `sops secrets.sops.yaml` (decrypts to your $EDITOR, re-encrypts on
# save).
#
# Keys map 1:1 to the `${GMED_*}` env vars docker-compose.release.yml
# substitutes into the backend container.

# --- backend ----------------------------------------------------------------
GMED_DATABASE_URL: "postgres://gmed:gmed@postgres:5432/gmed"

# 48+ random bytes. Generate locally: openssl rand -base64 48
GMED_JWT_SECRET: "REPLACE-WITH-openssl-rand-base64-48-output"

# Comma-separated list of `keyid:base64-32-bytes`. The active id below
# must match one of these. Generate a new 32-byte key: openssl rand -base64 32
GMED_MESSAGE_ENCRYPTION_KEYS: "v1:REPLACE-WITH-openssl-rand-base64-32-output"
GMED_MESSAGE_ENCRYPTION_KEY_ACTIVE: "v1"

# Stable salt for IP pseudonymisation in the audit log. Rotating it
# breaks historical correlation, so commit to one and keep it for the
# life of the environment. openssl rand -base64 32
GMED_AUDIT_IP_SALT: "REPLACE-WITH-openssl-rand-base64-32-output"

# Must match the public hostname Caddy serves (CADDY_HOSTNAME below).
GMED_CORS_ORIGIN: "https://console-dev.gmed-health.com"

# --- edge proxy / Caddy -----------------------------------------------------
CADDY_HOSTNAME: "console-dev.gmed-health.com"

# Used as the ACME contact address. Let's Encrypt sends expiry and
# policy notices here.
ACME_EMAIL: "ops@gmed-health.com"

# --- Loki shipper URL (Phase 3e5) -------------------------------------------
# Promtail on DEV pushes container + syslog to Loki on the monitoring
# host via the tailnet. `gmed-monitoring` resolves via Tailscale
# MagicDNS — override with the literal 100.x.y.z if MagicDNS is off.
LOKI_URL: "http://gmed-monitoring:3100/loki/api/v1/push"
