DATABASE_URL=postgres://gmed:gmed@localhost:5432/gmed
PORT=3000

# JWT signing secret. Generate with: openssl rand -base64 48
# Server REFUSES to start if this is unset or matches a known placeholder.
JWT_SECRET=REPLACE_ME_WITH_FRESH_SECRET

# Message encryption key registry. Format: `id1:base64key,id2:base64key,...`
# Each key must decode to exactly 32 bytes (AES-256). Generate with:
#   openssl rand -base64 32
#
# Rotation procedure:
#   1. Generate a fresh key, append it to MESSAGE_ENCRYPTION_KEYS.
#   2. Set MESSAGE_ENCRYPTION_KEY_ACTIVE to the new id, restart.
#   3. New writes use the new key. Old writes still readable thanks to the
#      old key remaining in the registry.
#   4. Run POST /admin/security/key-rotation/rewrap repeatedly (or wait for
#      the periodic background sweep) until status reports 100% on the
#      active id.
#   5. Remove the old key from MESSAGE_ENCRYPTION_KEYS, restart again.
MESSAGE_ENCRYPTION_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
MESSAGE_ENCRYPTION_KEY_ACTIVE=v1
# Optional but recommended in production so JWT rotation does not destroy
# audit-log IP hash continuity. Generate with: openssl rand -base64 32
AUDIT_IP_SALT=REPLACE_ME_WITH_FRESH_SALT

# Public frontend origin. For the bundled container stack this is usually
# http://localhost:8080 locally and your ALB / domain origin in AWS.
CORS_ORIGIN=http://localhost:8080
RUST_LOG=info,gmed_server=debug

# For `docker compose -f docker-compose.yml -f docker-compose.release.yml ...`
# prefer separate release variables so the container stack does not accidentally
# inherit local dev values from `.env`.
# GMED_DATABASE_URL=postgres://gmed:gmed@postgres:5432/gmed
# GMED_JWT_SECRET=REPLACE_ME_WITH_FRESH_SECRET
# GMED_MESSAGE_ENCRYPTION_KEYS=v1:REPLACE_WITH_BASE64_32_BYTES
# GMED_MESSAGE_ENCRYPTION_KEY_ACTIVE=v1
# GMED_AUDIT_IP_SALT=REPLACE_ME_WITH_FRESH_SALT
# GMED_CORS_ORIGIN=http://localhost:8080
# GMED_LEAD_INTAKE_TOKEN=REPLACE_ME_WITH_SHARED_WEBSITE_INTAKE_TOKEN
# GMED_RUST_LOG=info,gmed_server=debug
